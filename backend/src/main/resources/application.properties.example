spring.application.name=elitan-backend

# --- KẾT NỐI AIVEN ---
# Lưu ý: Kiểm tra kỹ từng chữ trong dòng url này, không được thừa dấu cách
spring.datasource.url=jdbc:mysql://avnadmin:password@mysql-url:port/defaultdb?ssl-mode=REQUIRED
spring.datasource.username=avnadmin
spring.datasource.password=YOUR_DB_PASSWORD_HERE

# --- CẤU HÌNH KHÁC ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# --- JWT CONFIG ---
jwt.secret=YOUR_JWT_SECRET_KEY_HERE
jwt.expiration=86400000

# --- SOCIAL LOGIN ---
google.client-id=YOUR_GOOGLE_CLIENT_ID_HERE
facebook.app-id=YOUR_FACEBOOK_APP_ID_HERE
