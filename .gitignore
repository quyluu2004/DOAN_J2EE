# ========================
# Root .gitignore - ÉLITAN
# ========================

# === Logs ===
*.log

# === Java / Maven (Backend) ===
target/


# === Node.js (Frontend) ===
node_modules/
dist/

# === Environment & Secrets ===
.env
.env.local
.env.*.local

# === IDE / Editor ===
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# === OS Files ===
*.swp
*.swo
*~

# === GitNexus ===
.gitnexus/

# === Docker ===
.dockerignore

# === Misc ===
*.zip
tmp_*.json
.planning/

# === AI Agents & Logs ===
.claude/
.gitnexus_backup*/
err.txt
out.txt
out.log
err.log

# === Markdown Files ===
# Ignore all .md files by default
*.md
# But keep these essential documentation files
!README.md
!README_vn.md
!frontend/README.md
!backend/HELP.md
